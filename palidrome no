#include <stdio.h>

int main() {
   int num,digit,original,reversed =0;
   printf("enter the number\n");
   scanf("%d",&num);
   original=num;
   while(num>0){
       digit=num%10;
       reversed=reversed*10+digit;
       num=num/10;
   }
   if(original==reversed){
       printf("number is palidrome\n");
   }
   else
   {
       printf("number is not palidrome\n");
   }
    return 0;
}